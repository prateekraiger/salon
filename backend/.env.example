# ==========================================
# Luxe Salon Backend Configuration
# ==========================================

# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ==========================================
# Supabase Database (Required)
# Get these from your Supabase project settings → API
# ==========================================
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret_key_here

# ==========================================
# Razorpay Payment Gateway (Required for online payments)
# Get these from Razorpay Dashboard → Settings → API Keys
# ==========================================
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=your_razorpay_secret_here
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here (optional but recommended)

# ==========================================
# Twilio WhatsApp (Optional - for COD notifications)
# Get these from Twilio Console
# ==========================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
SALON_WHATSAPP_NUMBER=whatsapp:+91XXXXXXXXXX

# ==========================================
# Security (Required)
# Use strong random strings (at least 32 characters)
# ==========================================
ADMIN_SECRET_KEY=change_this_to_a_very_long_random_string_min_32_chars
JWT_SECRET=change_this_to_another_long_random_string_for_jwt_signing

# ==========================================
# Notes:
# - Never commit the actual .env file to git
# - Keep your SUPABASE_SERVICE_ROLE_KEY secret
# - In production, use strong randomly generated keys
# - Set NODE_ENV=production in production
# ==========================================
